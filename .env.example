# Copy to .env on the server (never commit .env)
GITHUB_TOKEN=ghp_your_token_here
# owner/repo only (not the full https://github.com/... URL)
GITHUB_REPO=your-username/mmtvpro
GITHUB_BRANCH=main
GITHUB_EMAIL=bot@local
GITHUB_NAME=mmtvpro-bot
SYNC_INTERVAL_MINUTES=5
# Set to 0 to scrape highlight.json (today + last 4 days) on each sync
SKIP_HIGHLIGHTS=0
# Sync uploads only JSON files whose content changed since the last local copy
# SKIP_SCRAPE=1
# Comma-separated JSON files uploaded to GitHub (repo root only)
# SYNC_FILES=soco.json,highlight.json,myanmartv.json

# Movies scraper (mycinema.asia) - runs on its own 15-day schedule
# MOVIES_SYNC_INTERVAL_DAYS=15
# Optional login token from mycinema.asia for m3u8 watch links in movies.json
# MYCINEMA_TOKEN=
